# Public site URL used for metadata, canonical links, robots & sitemap.
NEXT_PUBLIC_SITE_URL=https://medtour.kz

# Google OAuth — required for Sign in with Google (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# Add authorized JavaScript origins: http://localhost:3000 and your production domain
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: webhook URL for consultation / request form submissions
CONSULTATION_WEBHOOK_URL=
